{
  "name": "demo-webdriverio-typescript",
  "version": "0.1.0",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "@wdio/cli": "^8.1.2",
    "@wdio/local-runner": "^8.1.2",
    "@wdio/mocha-framework": "^8.1.2",
    "@wdio/spec-reporter": "^8.1.2",
    "chromedriver": "^108.0.0",
    "eslint": "^8.31.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-wdio": "^8.0.14",
    "geckodriver": "^3.2.0",
    "prettier": "^2.8.1",
    "ts-node": "^10.9.1",
    "typescript": "^4.9.4",
    "wdio-chromedriver-service": "^8.0.1",
    "wdio-geckodriver-service": "^4.0.0"
  },
  "scripts": {
    "test": "wdio run config/wdio.conf.ts",
    "test:chrome": "wdio run config/wdio.conf.ts",
    "test:firefox": "wdio run config/wdio.ff.conf.ts",
    "lint": "eslint --ext .ts . --fix",
